generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Result {
  id         String   @id
  cookedPct  Int
  archetype  String
  stats      String
  diagnostic String
  answers    String
  yap        String?
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
